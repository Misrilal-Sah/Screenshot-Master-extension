{
  "manifest_version": 3,
  "name": "Screenshot Master",
  "version": "2.1.2",
  "description": "Capture visible area, full page, or selected region screenshots with annotation tools.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com;"
  },
  "commands": {
    "capture-visible": {
      "suggested_key": {
        "default": "Alt+Shift+V"
      },
      "description": "Capture visible area screenshot"
    },
    "capture-full-page": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Capture full page screenshot"
    },
    "capture-selected": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Capture selected area screenshot"
    }
  }
}
